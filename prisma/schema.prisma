generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

model character {
  id               Int     @id @default(autoincrement())
  slug             String? @db.VarChar(255)
  name             String? @db.VarChar(255)
  title            String? @db.VarChar(255)
  description      String? @db.VarChar(255)
  weapon_type      String? @db.VarChar(255)
  weapon_text      String? @db.VarChar(255)
  body_type        String? @db.VarChar(255)
  gender           String? @db.VarChar(255)
  quality_type     String? @db.VarChar(255)
  rarity           Int?
  /// [characterBirthday]
  birthday         Json?
  element_type     String? @db.VarChar(255)
  element_text     String? @db.VarChar(255)
  affiliation      String? @db.VarChar(255)
  association_type String? @db.VarChar(255)
  region           String? @db.VarChar(255)
  /// [characterCV]
  cv               Json?
  /// [characterStats]
  stats            Json?
  /// [characterCosts]
  costs            Json?
  /// [characterTalents]
  talents          Json?
  /// [characterPassives]
  passives         Json?
  /// [characterConstellation]
  constellation    Json?
  /// [characterDictionary]
  dictionary       Json?
  /// [characterProfile]
  profile          Json?
  /// [characterImages]
  images           Json?
  version          String? @db.VarChar(255)
  releasetimestamp Int?
  /// [characterOutfits]
  outfits          Json?   @default("[]")
}
